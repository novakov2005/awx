---
- name: Check disk usage
  hosts: all
  become: yes
  tasks:

    - name: Get disk usage
      shell: df -h / | awk 'NR==2 {print $5}' | sed 's/%//'
      register: disk_usage

    - name: Show disk usage
      debug:
        msg: "Disk usage is {{ disk_usage.stdout }}%"

    - name: Fail if usage exceeds threshold
      fail:
        msg: "Disk usage exceeded threshold: {{ disk_usage.stdout }}%"
      when: disk_usage.stdout | int > 80
